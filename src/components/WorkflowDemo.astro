<div class="relative rounded-xl border border-line bg-white p-4 shadow-lift sm:p-6 lg:p-7" aria-label="Beispiel eines automatisierten E-Mail-Workflows">
  <div class="mb-5 border-b border-line pb-4">
    <p class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-primary">Beispiel-Workflow</p>
    <p class="mt-1 text-sm text-soft">Kundenanfrage → geprüfter Entwurf</p>
  </div>

  <ol class="relative">
    <li class="workflow-step relative grid grid-cols-[26px_1fr] gap-3 pb-4">
      <div class="relative z-10 grid size-[26px] place-items-center rounded-md border border-line bg-surface font-mono text-[0.62rem] text-faint">01</div>
      <div class="rounded-lg border border-line bg-surface p-4">
        <div class="flex flex-wrap items-center justify-between gap-2">
          <p class="text-sm font-semibold text-ink">Neue Kundenanfrage</p>
          <span class="font-mono text-[0.62rem] text-faint">08:42</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-soft">«Können Sie uns bis Freitag eine Offerte für die Wartung senden?»</p>
      </div>
      <span class="absolute bottom-0 left-[12px] top-[26px] w-px bg-line" aria-hidden="true"></span>
    </li>

    <li class="workflow-step relative grid grid-cols-[26px_1fr] gap-3 pb-4">
      <div class="relative z-10 grid size-[26px] place-items-center rounded-md border border-line bg-surface font-mono text-[0.62rem] text-faint">02</div>
      <div class="flex flex-wrap items-center gap-2 rounded-lg border border-line bg-surface-strong p-4">
        <span class="rounded-md bg-primary px-2 py-1 font-mono text-[0.6rem] font-semibold uppercase tracking-[0.08em] text-white">Offerte</span>
        <span class="rounded-md border border-line bg-white px-2 py-1 font-mono text-[0.6rem] text-soft">Priorität: hoch</span>
        <span class="text-sm text-soft">automatisch erkannt</span>
      </div>
      <span class="absolute bottom-0 left-[12px] top-[26px] w-px bg-line" aria-hidden="true"></span>
    </li>

    <li class="workflow-step relative grid grid-cols-[26px_1fr] gap-3 pb-4">
      <div class="relative z-10 grid size-[26px] place-items-center rounded-md border border-line bg-surface font-mono text-[0.62rem] text-faint">03</div>
      <div class="rounded-lg border border-line bg-surface p-4">
        <p class="text-sm font-semibold text-ink">Antwortentwurf vorbereitet</p>
        <p class="mt-2 text-sm leading-6 text-soft">Termin, Konditionen und Kundenton wurden aus Ihren bestehenden Angaben übernommen.</p>
      </div>
      <span class="absolute bottom-0 left-[12px] top-[26px] w-px bg-line" aria-hidden="true"></span>
    </li>

    <li class="workflow-step grid grid-cols-[26px_1fr] gap-3">
      <div class="grid size-[26px] place-items-center rounded-md bg-primary text-white" aria-hidden="true">
        <svg viewBox="0 0 20 20" class="size-3.5" fill="none" stroke="currentColor" stroke-width="2.2">
          <path d="m4 10 4 4 8-9"></path>
        </svg>
      </div>
      <div class="flex flex-col justify-between gap-4 rounded-lg bg-primary p-4 text-white sm:flex-row sm:items-center">
        <div>
          <p class="text-sm font-bold">Bereit für Ihre Freigabe</p>
          <p class="mt-1 text-sm text-white/75">Nichts wird ohne Sie versendet.</p>
        </div>
        <span class="font-mono text-[0.66rem] font-semibold uppercase tracking-[0.1em]">prüfen → senden</span>
      </div>
    </li>
  </ol>
</div>
