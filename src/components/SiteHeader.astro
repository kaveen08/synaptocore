---
import BrandMark from "./BrandMark.astro";
---

<header class="sticky top-0 z-40 border-b border-line bg-site">
  <div class="mx-auto flex h-[72px] max-w-[1180px] items-center justify-between gap-4 px-5 sm:px-8">
    <a href="#top" aria-label="SynaptoCore Startseite" class="inline-flex min-h-11 shrink-0 items-center rounded-sm">
      <BrandMark />
    </a>

    <nav aria-label="Hauptnavigation" class="hidden items-center gap-7 md:flex">
      <a class="inline-flex min-h-11 items-center text-sm font-medium text-soft transition-colors duration-200 hover:text-ink" href="#leistung">Leistung</a>
      <a class="inline-flex min-h-11 items-center text-sm font-medium text-soft transition-colors duration-200 hover:text-ink" href="#ablauf">Ablauf</a>
      <a class="inline-flex min-h-11 items-center text-sm font-medium text-soft transition-colors duration-200 hover:text-ink" href="#sicherheit">Sicherheit</a>
    </nav>

    <a
      href="#kontakt"
      class="inline-flex min-h-11 items-center justify-center bg-signal px-4 text-sm font-semibold text-site transition-transform duration-200 ease-site hover:-translate-y-0.5 sm:px-5"
    >
      <span class="sm:hidden">Gespräch</span>
      <span class="hidden sm:inline">Erstgespräch anfragen</span>
    </a>
  </div>
</header>
