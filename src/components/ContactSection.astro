<section id="kontakt" class="py-20 sm:py-28">
  <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
    <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-20">
      <div>
        <p class="font-mono text-xs font-semibold text-signal">Erstgespräch</p>
        <h2 class="mt-5 max-w-[12ch] text-4xl font-semibold leading-[1.04] tracking-[-0.035em] text-ink sm:text-5xl">
          Wo verliert Ihr Team heute Zeit?
        </h2>
        <p class="mt-6 max-w-[48ch] text-lg leading-8 text-soft">
          Beschreiben Sie uns kurz den Engpass. Wir melden uns innerhalb von 24 Stunden mit einer ehrlichen ersten Einschätzung.
        </p>

        <div class="mt-10 border-t border-line pt-7">
          <p class="text-sm text-soft">Lieber direkt?</p>
          <div class="mt-3 flex flex-col items-start gap-2 text-base">
            <a class="inline-flex min-h-11 items-center font-semibold text-ink underline decoration-line underline-offset-4 transition-colors hover:decoration-signal" href="mailto:synaptocore@gmail.com">synaptocore@gmail.com</a>
            <a class="inline-flex min-h-11 items-center font-semibold text-ink underline decoration-line underline-offset-4 transition-colors hover:decoration-signal" href="tel:+41788090094">+41 78 809 00 94</a>
          </div>
        </div>
      </div>

      <div class="border border-line bg-panel p-5 sm:p-8">
        <form id="anfrage-form" name="anfrage" method="POST" accept-charset="UTF-8" novalidate>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label class="mb-2 block text-sm font-semibold text-ink" for="f-name">Vollständiger Name</label>
              <input
                class="min-h-12 w-full border border-line bg-site px-4 text-base text-ink outline-none transition-colors placeholder:text-soft focus:border-signal"
                type="text"
                id="f-name"
                name="name"
                placeholder="Max Muster"
                autocomplete="name"
                maxlength="160"
                required
              />
            </div>
            <div>
              <label class="mb-2 block text-sm font-semibold text-ink" for="f-firma">Firma</label>
              <input
                class="min-h-12 w-full border border-line bg-site px-4 text-base text-ink outline-none transition-colors placeholder:text-soft focus:border-signal"
                type="text"
                id="f-firma"
                name="firma"
                placeholder="Muster AG"
                autocomplete="organization"
                maxlength="200"
                required
              />
            </div>
            <div class="sm:col-span-2">
              <label class="mb-2 block text-sm font-semibold text-ink" for="f-email">E-Mail-Adresse</label>
              <input
                class="min-h-12 w-full border border-line bg-site px-4 text-base text-ink outline-none transition-colors placeholder:text-soft focus:border-signal"
                type="email"
                id="f-email"
                name="email"
                placeholder="max@muster.ch"
                autocomplete="email"
                maxlength="320"
                required
              />
            </div>
            <div class="sm:col-span-2">
              <label class="mb-2 block text-sm font-semibold text-ink" for="f-nachricht">Wo verliert Ihr Team aktuell am meisten Zeit?</label>
              <textarea
                class="min-h-36 w-full resize-y border border-line bg-site px-4 py-3 text-base text-ink outline-none transition-colors placeholder:text-soft focus:border-signal"
                id="f-nachricht"
                name="nachricht"
                placeholder="Zum Beispiel: Anfragen sortieren, Angaben ins CRM übertragen und Antworten vorbereiten."
                maxlength="2000"
                required
              ></textarea>
            </div>

            <div class="absolute -left-[10000px] top-auto size-px overflow-hidden" aria-hidden="true">
              <label for="f-website">Website</label>
              <input type="text" id="f-website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <p
              class="sm:col-span-2 border border-danger/50 bg-danger/10 p-3 text-sm text-danger"
              id="form-error"
              role="alert"
              aria-live="assertive"
              tabindex="-1"
              hidden
            >
              Ihre Anfrage konnte nicht gesendet werden. Die Eingaben bleiben erhalten – bitte versuchen Sie es erneut oder kontaktieren Sie uns direkt.
            </p>
            <p
              class="sm:col-span-2 border border-signal/50 bg-signal/10 p-3 text-sm text-ink"
              id="form-cooldown"
              role="status"
              aria-live="polite"
              tabindex="-1"
              hidden
            >
              Bitte warten Sie eine Minute, bevor Sie eine weitere Anfrage senden.
            </p>

            <div class="flex flex-col items-start justify-between gap-5 pt-1 sm:col-span-2 sm:flex-row sm:items-center">
              <p class="max-w-[42ch] text-xs leading-5 text-soft">Ihre Angaben werden ausschliesslich zur Bearbeitung Ihrer Anfrage verwendet.</p>
              <button
                type="submit"
                class="inline-flex min-h-12 w-full shrink-0 items-center justify-center bg-signal px-6 text-sm font-bold text-site transition-transform duration-200 ease-site hover:-translate-y-0.5 disabled:opacity-60 sm:w-auto"
              >
                Erstgespräch anfragen
              </button>
            </div>
          </div>
        </form>

        <div id="form-success" role="status" aria-live="polite" tabindex="-1" hidden>
          <div class="grid min-h-[25rem] place-items-center py-10 text-center">
            <div class="max-w-md">
              <span class="mx-auto grid size-12 place-items-center bg-success text-site" aria-hidden="true">
                <svg viewBox="0 0 24 24" class="size-6" fill="none" stroke="currentColor" stroke-width="2.4">
                  <path d="m5 12 4 4L19 6"></path>
                </svg>
              </span>
              <h3 class="mt-6 text-2xl font-semibold tracking-[-0.025em] text-ink">Anfrage erhalten.</h3>
              <p class="mt-3 text-base leading-7 text-soft">Wir prüfen Ihre Angaben und melden uns innerhalb von 24 Stunden mit einer ersten Einschätzung.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
