<script>
  const dialogTriggers = document.querySelectorAll<HTMLElement>("[data-legal]");
  const returnFocus = new WeakMap<HTMLDialogElement, HTMLElement>();

  dialogTriggers.forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const name = trigger.dataset.legal;
      const dialog = document.querySelector<HTMLDialogElement>(`#legal-${name}`);
      if (!dialog) return;

      returnFocus.set(dialog, trigger);
      dialog.showModal();
      document.body.style.overflow = "hidden";
      dialog.scrollTop = 0;
      window.requestAnimationFrame(() => dialog.querySelector<HTMLElement>("[data-legal-close]")?.focus());
    });
  });

  document.querySelectorAll<HTMLDialogElement>("dialog[id^='legal-']").forEach((dialog) => {
    dialog.querySelector<HTMLElement>("[data-legal-close]")?.addEventListener("click", () => dialog.close());

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });

    dialog.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      event.preventDefault();
      dialog.close();
    });

    dialog.addEventListener("close", () => {
      document.body.style.overflow = "";
      returnFocus.get(dialog)?.focus();
    });
  });
</script>
