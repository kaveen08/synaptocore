---
interface Props {
  compact?: boolean;
  /** Invert text color for use on the navy footer band. */
  inverted?: boolean;
}

const { compact = false, inverted = false } = Astro.props;
---

<img
  src={inverted ? "/systemio-logo-white.svg" : "/systemio-logo.svg"}
  alt="Systemio"
  class:list={["h-7 w-auto", compact && "sm:h-7"]}
  width="690"
  height="170"
/>
