---
export interface Props {
  title: string;
  description: string;
  robots?: string;
}

const { title, description, robots } = Astro.props;
const base = import.meta.env.BASE_URL; // "/synaptocore/"
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="de-CH">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
{robots && <meta name="robots" content={robots}>}
<link rel="canonical" href={canonical}>
<meta property="og:type" content="website">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonical}>
<meta property="og:locale" content="de_CH">
<meta name="theme-color" content="#0a0e1a">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%230a0e1a'/%3E%3Crect x='28' y='28' width='44' height='44' rx='9' fill='%233b82f6'/%3E%3C/svg%3E">
<link rel="stylesheet" href={`${base}style.css?v=3`}>
</head>
<body>
<slot />
<script src={`${base}script.js?v=3`}></script>
</body>
</html>
