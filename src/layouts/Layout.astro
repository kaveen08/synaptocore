---
import "../styles/site.css";

export interface Props {
  title: string;
  description: string;
  robots?: string;
}

const { title, description, robots } = Astro.props;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : undefined;
---
<!DOCTYPE html>
<html lang="de-CH">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
{robots && <meta name="robots" content={robots}>}
{canonical && <link rel="canonical" href={canonical}>}
<meta property="og:type" content="website">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
{canonical && <meta property="og:url" content={canonical}>}
<meta property="og:locale" content="de_CH">
<meta name="theme-color" content="#0b0d0e">
<meta name="color-scheme" content="dark">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%230b0d0e'/%3E%3Cpath d='M24 50h52' stroke='%23ff6b1a' stroke-width='10'/%3E%3Crect x='18' y='42' width='16' height='16' fill='%23ff6b1a'/%3E%3Crect x='68' y='42' width='16' height='16' fill='%230b0d0e' stroke='%23ff6b1a' stroke-width='5'/%3E%3C/svg%3E">
</head>
<body>
<a href="#main-content" class="fixed left-4 top-4 z-50 -translate-y-24 bg-signal px-4 py-3 text-sm font-bold text-site transition-transform focus:translate-y-0">
  Zum Inhalt springen
</a>
<slot />
</body>
</html>
