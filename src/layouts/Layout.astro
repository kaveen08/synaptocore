---
import "../styles/site.css";

export interface Props {
  title: string;
  description: string;
  robots?: string;
}

const { title, description, robots } = Astro.props;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : undefined;
---
<!DOCTYPE html>
<html lang="de-CH">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
{robots && <meta name="robots" content={robots}>}
{canonical && <link rel="canonical" href={canonical}>}
<meta property="og:type" content="website">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
{canonical && <meta property="og:url" content={canonical}>}
<meta property="og:locale" content="de_CH">
<meta name="theme-color" content="#ffffff">
<meta name="color-scheme" content="light">
<link rel="icon" type="image/svg+xml" href="/systemio-mark.svg">
</head>
<body>
<a href="#main-content" class="fixed left-4 top-4 z-50 -translate-y-24 rounded-lg bg-primary px-4 py-3 text-sm font-bold text-white shadow-lift transition-transform focus:translate-y-0">
  Zum Inhalt springen
</a>
<slot />
</body>
</html>
