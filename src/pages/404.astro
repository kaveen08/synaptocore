---
import BrandMark from "../components/BrandMark.astro";
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Seite nicht gefunden — SynaptoCore"
  description="Die angeforderte Seite wurde nicht gefunden."
  robots="noindex"
>
  <main id="main-content" class="grid min-h-svh place-items-center px-5 py-16 text-center">
    <div class="max-w-2xl">
      <a href={base} aria-label="SynaptoCore Startseite" class="inline-flex min-h-11 items-center">
        <BrandMark />
      </a>
      <p class="mt-16 font-mono text-sm font-semibold text-signal">Fehler 404</p>
      <h1 class="mt-5 text-[clamp(3rem,9vw,5.5rem)] font-semibold leading-[0.96] tracking-[-0.04em] text-ink">
        Hier endet der Ablauf.
      </h1>
      <p class="mx-auto mt-6 max-w-[46ch] text-lg leading-8 text-soft">
        Diese Seite existiert nicht oder wurde verschoben. Auf der Startseite finden Sie wieder den richtigen Einstieg.
      </p>
      <a
        class="mt-9 inline-flex min-h-12 items-center justify-center bg-signal px-6 text-sm font-bold text-site transition-transform duration-200 ease-site hover:-translate-y-0.5"
        href={base}
      >
        Zur Startseite
      </a>
    </div>
  </main>
</Layout>
