---
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="de-CH">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Seite nicht gefunden — SynaptoCore</title>
<meta name="robots" content="noindex">
<meta name="theme-color" content="#0a0e1a">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%230a0e1a'/%3E%3Crect x='28' y='28' width='44' height='44' rx='9' fill='%233b82f6'/%3E%3C/svg%3E">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; }
body {
  background: #0a0e1a;
  color: #f4f6fb;
  font-family: "Helvetica Neue", Helvetica, Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
  display: grid;
  place-items: center;
  padding: 24px;
  text-align: center;
  background-image: radial-gradient(ellipse 70% 55% at 50% 0%, rgba(59, 130, 246, 0.14), transparent 70%);
}
.mark {
  width: 12px; height: 12px; border-radius: 3px;
  background: #3b82f6;
  box-shadow: 0 0 14px rgba(59, 130, 246, 0.8);
  display: inline-block;
  margin-bottom: 26px;
}
h1 { font-size: clamp(2.2rem, 6vw, 3.4rem); letter-spacing: -0.02em; margin-bottom: 12px; }
p  { color: #a7b0c4; margin-bottom: 34px; font-size: 1.05rem; }
a.btn {
  display: inline-block;
  background: #3b82f6;
  color: #fff;
  text-decoration: none;
  font-weight: 600;
  padding: 13px 30px;
  border-radius: 999px;
  box-shadow: 0 4px 24px rgba(59, 130, 246, 0.35);
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}
a.btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(59, 130, 246, 0.5); }
</style>
</head>
<body>
<main>
  <span class="mark" aria-hidden="true"></span>
  <h1>404 — Seite nicht gefunden</h1>
  <p>Diese Seite existiert nicht (mehr). Zurück zur Startseite?</p>
  <a class="btn" href={base}>Zur Startseite</a>
</main>
</body>
</html>
